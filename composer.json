{
    "name": "mathieu-mont/mobilite-stephanoise",
    "description": "Mobilité Saint-Étienne — STAS + Vélivert open data unified backend",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.3",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "ext-pdo": "*",
        "ext-zip": "*",
        "doctrine/dbal": "^4.2",
        "doctrine/doctrine-bundle": "^2.13",
        "doctrine/doctrine-migrations-bundle": "^3.3",
        "doctrine/orm": "^3.3",
        "dragonmantank/cron-expression": "^3.4",
        "symfony/asset": "7.2.*",
        "symfony/console": "^7.2",
        "symfony/doctrine-messenger": "7.2.*",
        "symfony/dotenv": "^7.2",
        "symfony/flex": "*",
        "symfony/framework-bundle": "^7.2",
        "symfony/http-client": "^7.2",
        "symfony/messenger": "^7.2",
        "symfony/monolog-bundle": "^3.10",
        "symfony/runtime": "^7.2",
        "symfony/scheduler": "^7.2",
        "symfony/serializer": "^7.2",
        "symfony/twig-bundle": "^7.2",
        "symfony/yaml": "^7.2",
        "twig/twig": "^3.0"
    },
    "require-dev": {
        "symfony/maker-bundle": "^1.61",
        "symfony/web-profiler-bundle": "^7.2"
    },
    "config": {
        "allow-plugins": {
            "symfony/runtime": true,
            "symfony/flex": true
        },
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd"
        },
        "post-install-cmd": ["@auto-scripts"],
        "post-update-cmd": ["@auto-scripts"]
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "7.2.*"
        }
    }
}
