FROM nginx:1.27-alpine

# Static assets servis directement par nginx (CSS, JS, images, manifest PWA).
# Sans cette copie, nginx ne sait pas servir les fichiers de public/ et toutes
# les requêtes statiques retombent sur php-fpm via try_files → 404.
COPY public/ /var/www/html/public/

# Server config (root pointe sur /var/www/html/public, fastcgi_pass php:9000)
COPY docker/nginx/default.conf /etc/nginx/conf.d/default.conf
