# =============================================================================
# Variables d'env à renseigner côté Dokploy (Service → Environment).
# Ne PAS commit le .env.prod réel — ce fichier est juste l'exemple à copier.
# =============================================================================

# APP_SECRET — secret Symfony, génère avec `openssl rand -hex 16`
APP_SECRET=changeme

# Database (utilisé par le service `database` ET par DATABASE_URL plus bas)
POSTGRES_DB=furan
POSTGRES_USER=furan
POSTGRES_PASSWORD=changeme_strong_random

# DSN Doctrine — `database` est le hostname réseau du service Compose.
# Garde les mêmes user/db/password que ci-dessus.
DATABASE_URL="postgresql://furan:changeme_strong_random@database:5432/furan?serverVersion=16&charset=utf8"

# Sources open data
STAS_GTFS_URL=https://data.saint-etienne-metropole.fr/api/datasets/1.0/stas_horaires_theoriques/gtfs.zip
VELIVERT_GBFS_URL=https://api.cyclocity.fr/contracts/saintetienne/gbfs/gbfs.json

# Tag d'image GHCR à déployer. Laisse `latest` en routine ;
# fixe à `sha-XXXXXXX` pour un rollback manuel sur une image précédente.
IMAGE_TAG=latest
