{% extends 'base.html.twig' %}

{% block title %}Mobilité Stéphanoise — STAS · Vélivert{% endblock %}

{% block body %}
<div class="app">
    <aside class="panel">
        <header class="brand">
            <div class="brand__mark">45.44°N · 4.39°E</div>
            <h1 class="brand__title">Mobilité<br><em>Stéphanoise</em></h1>
            <p class="brand__sub">STAS · Vélivert · temps réel</p>
            <a class="brand__board-link" href="{{ path('board') }}">→ Mode board mobile</a>
        </header>

        <section class="search">
            <label for="stop-search" class="search__label">Rechercher un arrêt</label>
            <input type="search" id="stop-search" class="search__input" placeholder="Place du Peuple, Châteaucreux…" autocomplete="off">
            <ul class="search__results" id="search-results" hidden></ul>
        </section>

        <section class="board" id="departure-board">
            <header class="board__head">
                <span class="board__title">Prochains passages</span>
                <span class="board__hint" id="board-hint">— Sélectionnez un arrêt</span>
            </header>
            <ol class="board__list" id="board-list"></ol>
        </section>

        <section class="legend">
            <span class="legend__pill legend__pill--tram">tram</span>
            <span class="legend__pill legend__pill--bus">bus</span>
            <span class="legend__pill legend__pill--bike">vélivert</span>
        </section>
    </aside>

    <main class="map-wrap">
        <div id="map" class="map"></div>
        <div class="ticker">
            <span class="ticker__tick" id="clock">--:--:--</span>
            <span class="ticker__sep">·</span>
            <span class="ticker__info" id="velivert-summary">Vélivert : —</span>
        </div>
    </main>
</div>

<template id="tpl-departure">
    <li class="dep">
        <span class="dep__route" data-route></span>
        <span class="dep__sign" data-sign></span>
        <span class="dep__time" data-time></span>
        <span class="dep__eta" data-eta></span>
    </li>
</template>
{% endblock %}

{% block javascripts %}
<script src="{{ asset('js/app.js') }}" defer></script>
{% endblock %}
