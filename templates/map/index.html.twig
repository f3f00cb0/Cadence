{% extends 'base.html.twig' %}

{% block title %}Carte · Mobilité Stéphanoise — STAS · Vélivert{% endblock %}

{% block stylesheets %}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght,SOFT@9..144,400;9..144,500;9..144,600;9..144,800&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="{{ asset('css/map.css') }}">
<meta name="theme-color" content="#08090b">
<link rel="manifest" href="{{ asset('manifest.webmanifest') }}">
<link rel="apple-touch-icon" href="{{ asset('img/board-icon-192.png') }}">
{% endblock %}

{% block body %}
<div class="mp" id="mp-root" data-sheet-state="peek">

    {# ============================================================
       Sidebar (desktop) · Bottom sheet (mobile)
       ============================================================ #}
    <aside class="mp-aside" id="mp-aside">

        {# Drag handle — visible & interactive only on mobile #}
        <div class="mp-sheet-handle" id="mp-sheet-handle" aria-hidden="true">
            <span class="mp-sheet-handle__grip"></span>
        </div>

        {# Header — back-to-home + identité + horloge #}
        <header class="mp-head">
            <div class="mp-head__top">
                <a class="mp-head__back" href="{{ path('home') }}" aria-label="Retour à l'accueil">
                    <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M19 12H5"></path>
                        <path d="m12 19-7-7 7-7"></path>
                    </svg>
                    Accueil
                </a>
                <span class="mp-head__mark">
                    <span class="mp-head__pulse"></span><strong>SAINT-ÉTIENNE</strong>
                </span>
            </div>

            <h1 class="mp-head__title">
                Mobilité<br><em>Stéphanoise</em>
            </h1>

            <div class="mp-head__meta">
                <span class="mp-head__clock" id="clock" aria-live="polite">--:--:--</span>
                <span class="mp-head__live">
                    <span class="mp-head__live-dot"></span>
                    TEMPS RÉEL
                </span>
            </div>
        </header>

        {# Recherche — primary call-to-action in peek state #}
        <section class="mp-search">
            <div class="mp-search__wrap" id="mp-search-wrap">
                <svg class="mp-search__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <circle cx="11" cy="11" r="7"></circle>
                    <path d="m21 21-4.3-4.3"></path>
                </svg>
                <input type="search" id="stop-search" class="mp-search__input" placeholder="Châteaucreux, Bellevue…" autocomplete="off" enterkeyhint="search">
            </div>
            <ul class="mp-search__results" id="search-results" hidden role="listbox"></ul>
        </section>

        {# Couches — tram / bus / vélivert #}
        <section class="mp-layers">
            <div class="mp-section__head">
                <span class="mp-section__bar"></span>
                <h2 class="mp-section__title">COUCHES</h2>
            </div>
            <div class="mp-layers__pills">
                <button type="button" class="mp-pill mp-pill--tram is-on" data-layer="tram" aria-pressed="true">
                    <span class="mp-pill__dot mp-pill__dot--tram"></span> Tram
                </button>
                <button type="button" class="mp-pill mp-pill--bus is-on" data-layer="bus" aria-pressed="true">
                    <span class="mp-pill__dot mp-pill__dot--bus"></span> Bus
                </button>
                <button type="button" class="mp-pill mp-pill--velivert is-on" data-layer="velivert" aria-pressed="true">
                    <span class="mp-pill__dot mp-pill__dot--velivert"></span> Vélivert
                </button>
            </div>
        </section>

        {# Board des prochains passages #}
        <section class="mp-board" id="mp-board">
            <div class="mp-section__head">
                <span class="mp-section__bar"></span>
                <h2 class="mp-section__title">PROCHAINS PASSAGES</h2>
                <span class="mp-section__meta" id="board-hint">— Sélectionnez un arrêt</span>
            </div>
            <ol class="mp-board__list" id="board-list">
                <li class="mp-board__empty">
                    <p class="mp-board__empty-title">La carte attend votre choix</p>
                    <p class="mp-board__empty-sub">Cliquez sur un arrêt ou utilisez la recherche pour voir les prochains passages.</p>
                </li>
            </ol>
        </section>

        {# Footer — open data credits #}
        <footer class="mp-foot">
            <span class="mp-foot__creds">
                OPEN DATA SAINT-ÉTIENNE MÉTROPOLE
                <span class="mp-foot__sep">·</span>
                GTFS · GBFS
            </span>
        </footer>
    </aside>

    {# ============================================================
       Carte
       ============================================================ #}
    <main class="mp-map-wrap">
        <div id="map" class="mp-map" aria-label="Carte des transports stéphanois"></div>

        {# Overlay haut-gauche — accueil + légende #}
        <div class="mp-toolbar">
            <a class="mp-chip mp-chip--home" href="{{ path('home') }}" aria-label="Retour à l'accueil">
                <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="m3 12 9-9 9 9"></path>
                    <path d="M5 10v10a1 1 0 0 0 1 1h3v-6h6v6h3a1 1 0 0 0 1-1V10"></path>
                </svg>
                Accueil
            </a>
            <div class="mp-legend" aria-label="Légende">
                <span class="mp-legend__item">
                    <span class="mp-marker__chip mp-marker__chip--tram mp-marker__chip--legend">T</span>
                    Tram
                </span>
                <span class="mp-legend__item">
                    <span class="mp-marker__chip mp-marker__chip--bus mp-marker__chip--legend">B</span>
                    Bus
                </span>
                <span class="mp-legend__item">
                    <span class="mp-marker__chip mp-marker__chip--velivert mp-marker__chip--legend">V</span>
                    Vélivert
                </span>
            </div>
        </div>

        {# Overlay bas-centre — ticker live (desktop) #}
        <div class="mp-overlay mp-overlay--ticker" id="mp-ticker">
            <span class="mp-ticker__live">
                <span class="mp-ticker__dot"></span> LIVE
            </span>
            <span class="mp-ticker__sep"></span>
            <span class="mp-ticker__info" id="velivert-summary">Vélivert : —</span>
        </div>

        {# Floating action button (mobile) — ouvre la feuille à mi-hauteur #}
        <button type="button" class="mp-fab" id="mp-fab" aria-label="Ouvrir le panneau de recherche">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="11" cy="11" r="7"></circle>
                <path d="m21 21-4.3-4.3"></path>
            </svg>
        </button>
    </main>

    {# Scrim qui assombrit la carte quand la feuille est ouverte (mobile uniquement) #}
    <div class="mp-scrim" id="mp-scrim" aria-hidden="true"></div>
</div>

{# Template pour une ligne de départ #}
<template id="tpl-departure">
    <li class="mp-dep">
        <span class="mp-dep__route" data-route></span>
        <div class="mp-dep__main">
            <span class="mp-dep__sign" data-sign></span>
            <span class="mp-dep__time" data-time></span>
        </div>
        <span class="mp-dep__eta" data-eta></span>
    </li>
</template>
{% endblock %}

{% block javascripts %}
<script src="{{ asset('js/app.js') }}" defer></script>
{% endblock %}
